# Google Calendar service account
GCAL_CLIENT_EMAIL=
GCAL_PRIVATE_KEY_BASE64=

# Barber calendar IDs (optional — falls back to hardcoded defaults in lib/barbers.ts if unset)
GCAL_FABIAN_ID=
GCAL_ALEXIS_ID=
GCAL_LESS_ID=

# Owner's calendar — every booking is mirrored here so he sees all barbers' schedules
GCAL_OWNER_ID=

# SMTP mailbox used to send booking confirmation emails (e.g. Hostinger's no-reply@heliosbarber.com)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Supabase — SUPABASE_API_KEY must be the service_role key (server-only, bypasses RLS),
# not the anon key. Set these as env vars in hPanel's Node.js App config too (this file isn't deployed).
SUPABASE_URL=
SUPABASE_API_KEY=
